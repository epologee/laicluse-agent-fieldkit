#!/usr/bin/env node
import { parseArgs } from 'node:util';
import { claim, release, releaseAll, check, formatHolder, listExcludes, addExclude, removeExclude } from './dibs-lib.mjs';

const USAGE = `usage: dibs <command> <dir> [options]

commands:
  claim <dir>     take exclusive occupancy of a directory (refused if a live holder exists)
  release <dir>   release a directory you hold
  release-all     release every lock this session holds, across all directories
  release-all     selectors: --pid / --session / --owner with --agent; no <dir>
  check <dir>     report whether a directory is free or who holds it
  exclude         list directories dibs never locks (built-in defaults + configured)
  exclude add <dir>     never lock <dir> (persists to the excludes file)
  exclude remove <dir>  drop <dir> from the excludes file

options:
  --pid <n>            pid whose liveness defines the lock; pass your long-lived
                       agent or session pid (default: the calling process's
                       parent pid, correct only when that parent is the holder)
  --agent <name>       label the holder (e.g. claude, codex)
  --session <id>       holder session id
  --owner <id>         stable owner id across resumed sessions
  --legacy-codex-resume  allow a Codex resume to reclaim older ownerless Codex locks
  --nonce <hex>        on release, require this claim nonce to match the holder
  --max-age-hours <n>  treat a lock older than this as breakable (last-resort cap)
  --json               machine-readable output

run 'dibs --help' for this message`;

const [, , command, ...rest] = process.argv;

if (!command || command === '--help' || command === '-h') {
  console.log(USAGE);
  process.exit(command ? 0 : 2);
}

let wantJson = false;

function die(message) {
  if (wantJson) console.error(JSON.stringify({ error: message }));
  else console.error(`dibs: ${message}`);
  process.exit(1);
}

function parse(args) {
  return parseArgs({
    args,
    allowPositionals: true,
    options: {
      pid: { type: 'string' },
      agent: { type: 'string' },
      session: { type: 'string' },
      owner: { type: 'string' },
      'legacy-codex-resume': { type: 'boolean', default: false },
      nonce: { type: 'string' },
      'max-age-hours': { type: 'string' },
      json: { type: 'boolean', default: false },
    },
  });
}

if (!['claim', 'release', 'release-all', 'check', 'exclude'].includes(command)) {
  die(`unknown command: ${command}`);
}

let values;
let positionals;
try {
  ({ values, positionals } = parse(rest));
} catch (err) {
  if (err.code === 'ERR_PARSE_ARGS_UNKNOWN_OPTION') die(`${err.message.split('.')[0]} (run 'dibs --help')`);
  die(err.message);
}
wantJson = values.json;

function emit(result, human, exitCode = 0) {
  if (wantJson) console.log(JSON.stringify(result, null, 2));
  else console.log(human);
  process.exit(exitCode);
}

if (command === 'release-all') {
  const sweepPid = values.pid !== undefined ? Number(values.pid) : undefined;
  if (sweepPid !== undefined && (!Number.isInteger(sweepPid) || sweepPid <= 0)) die(`invalid --pid ${JSON.stringify(values.pid)}`);
  try {
    const result = releaseAll({ pid: sweepPid, session: values.session, owner: values.owner, agent: values.agent });
    emit(result, result.count === 0
      ? 'no locks held by this session; nothing to release'
      : `released ${result.count} lock${result.count === 1 ? '' : 's'}:\n${result.released.map((r) => `  ${r.realpath}`).join('\n')}`);
  } catch (err) {
    die(err.message);
  }
}

function formatExcludeList(info) {
  const lines = ['built-in defaults (always excluded):'];
  for (const entry of info.defaults) lines.push(`  ${entry}`);
  lines.push(`configured (${info.file}):`);
  if (info.configured.length === 0) lines.push('  (none)');
  else for (const entry of info.configured) lines.push(`  ${entry}`);
  return lines.join('\n');
}

function formatExcludeChange(result) {
  switch (result.state) {
    case 'added': return `added ${result.path}; dibs will not lock it (${result.file})`;
    case 'already-present': return `${result.path} is already in the excludes file`;
    case 'already-default': return `${result.path} is a built-in default; already excluded`;
    case 'removed': return `removed ${result.path} from ${result.file}`;
    case 'not-present': return `${result.path} was not configured; nothing to remove`;
    case 'is-default': return `${result.path} is a built-in default and cannot be removed`;
    default: return result.state;
  }
}

if (command === 'exclude') {
  const sub = positionals[0];
  try {
    if (!sub || sub === 'list') {
      emit(listExcludes(), formatExcludeList(listExcludes()));
    } else if (sub === 'add') {
      if (!positionals[1]) die('exclude add needs a directory path');
      const result = addExclude(positionals[1]);
      emit(result, formatExcludeChange(result));
    } else if (sub === 'remove' || sub === 'rm') {
      if (!positionals[1]) die('exclude remove needs a directory path');
      const result = removeExclude(positionals[1]);
      emit(result, formatExcludeChange(result));
    } else {
      die(`unknown exclude subcommand: ${sub} (use list, add, remove)`);
    }
  } catch (err) {
    die(err.message);
  }
}

const dir = positionals[0];
if (!dir) die(`${command} needs a directory path`);

const pid = values.pid !== undefined ? Number(values.pid) : process.ppid;
if (!Number.isInteger(pid) || pid <= 0) die(`invalid --pid ${JSON.stringify(values.pid)}`);
const maxAgeHours = values['max-age-hours'] !== undefined ? Number(values['max-age-hours']) : undefined;
if (maxAgeHours !== undefined && (Number.isNaN(maxAgeHours) || maxAgeHours < 0)) {
  die(`invalid --max-age-hours ${JSON.stringify(values['max-age-hours'])}`);
}

function claimRefusalMessage(result) {
  const holder = result.holder
    ? formatHolder(result.holder)
    : 'another live agent holds this directory';
  return `refused: ${holder}. ${result.suggestion}`;
}

try {
  if (command === 'claim') {
    const result = claim({
      dir,
      pid,
      agent: values.agent,
      session: values.session,
      owner: values.owner,
      maxAgeHours,
      legacyCodexResume: values['legacy-codex-resume'],
    });
    if (result.state === 'excluded') emit(result, `excluded ${result.realpath}; dibs does not lock this directory`);
    else if (result.state === 'claimed') emit(result, `claimed ${result.holder.realpath} (pid ${pid}${values.agent ? `, agent ${values.agent}` : ''})`);
    else if (result.state === 'held-by-self') emit(result, `already held by you (pid ${pid})`);
    else if (result.state === 'reclaimed-by-owner') emit(result, `reclaimed ${result.holder.realpath} for owner ${result.holder.owner} (pid ${pid})`);
    else if (result.state === 'took-over-stale') emit(result, `took over stale lock on ${result.holder.realpath} (previous ${result.brokeStale.reason}); now held (pid ${pid})`);
    else emit(result, claimRefusalMessage(result), 1);
  } else if (command === 'release') {
    const result = release({ dir, pid, nonce: values.nonce });
    if (result.state === 'released') emit(result, `released ${result.holder.realpath}`);
    else if (result.state === 'not-held') emit(result, 'not held; nothing to release');
    else emit(result, `refused: ${formatHolder(result.holder)}`, 1);
  } else {
    const result = check({ dir, maxAgeHours });
    if (result.state === 'excluded') emit(result, `excluded: ${result.realpath}; dibs does not lock this directory`);
    else if (result.state === 'free') emit(result, `free: ${result.realpath}`);
    else if (result.state === 'corrupt') emit(result, `corrupt lock for ${result.realpath}; the next claimer will break it`);
    else {
      const liveness = result.sameHost ? (result.alive ? 'alive' : 'dead') : 'foreign-host';
      emit(result, `${formatHolder(result.holder)} [${liveness}${result.stale ? ', stale' : ''}]`);
    }
  }
} catch (err) {
  die(err.message);
}
