function readJson(file) {
	return JSON.parse(fs.readFileSync(file, "utf8"));
}

function maybeReadJson(file, fallback) {
	if (!fs.existsSync(file)) return fallback;
	return readJson(file);
}

function cleanInline(value) {
	return value
		.replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
		.replace(/`([^`]+)`/g, "$1")
		.replace(/\*\*([^*]+)\*\*/g, "$1")
		.replace(/\*/g, "")
		.replace(/\s+/g, " ")
		.trim();
}

function firstSentence(value) {
	const cleaned = cleanInline(value);
	const match = cleaned.match(/^(.{80,220}?[.!?])\s/);
	return match ? match[1] : cleaned.slice(0, 190);
}

function briefChange(value) {
	const cleaned = cleanInline(value);
	const sentence = cleaned.match(/^(.{1,280}?[.!?])(?:\s|$)/);
	if (sentence) return sentence[1];
	if (cleaned.length <= 260) return cleaned;
	return `${cleaned.slice(0, 257).replace(/\s+\S*$/, "")}...`;
}

function htmlEscape(value) {
	return String(value)
		.replace(/&/g, "&amp;")
		.replace(/</g, "&lt;")
		.replace(/>/g, "&gt;")
		.replace(/"/g, "&quot;");
}

function attributeEscape(value) {
	return htmlEscape(value).replace(/'/g, "&#39;");
}

function slugifyHeading(value) {
	return cleanInline(value)
		.toLowerCase()
		.replace(/[^a-z0-9]+/g, "-")
		.replace(/^-|-$/g, "");
}

function renderInlineMarkdown(value) {
	const codeSpans = [];
	let withCodeSpans = "";
	for (let index = 0; index < value.length; index += 1) {
		if (value[index] !== "`") {
			withCodeSpans += value[index];
			continue;
		}

		let tickEnd = index;
		while (value[tickEnd] === "`") tickEnd += 1;
		const fence = value.slice(index, tickEnd);
		const closeIndex = value.indexOf(fence, tickEnd);
		if (closeIndex === -1) {
			withCodeSpans += fence;
			index = tickEnd - 1;
			continue;
		}

		let code = value.slice(tickEnd, closeIndex);
		if (/^ .*\S.* $/.test(code)) code = code.slice(1, -1);
		const token = `\u0000CODE${codeSpans.length}\u0000`;
		codeSpans.push(`<code>${htmlEscape(code)}</code>`);
		withCodeSpans += token;
		index = closeIndex + fence.length - 1;
	}

	const rendered = htmlEscape(withCodeSpans)
		.replace(/\[([^\]]+)\]\(([^)\s]+)\)/g, (_, label, url) => {
			return `<a href="${attributeEscape(url)}">${label}</a>`;
		})
		.replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>")
		.replace(/\*([^*]+)\*/g, "<em>$1</em>");

	return codeSpans.reduce((result, html, index) => result.replace(`\u0000CODE${index}\u0000`, html), rendered);
}

function isTableSeparator(line) {
	return line
		.trim()
		.replace(/^\||\|$/g, "")
		.split("|")
		.every((cell) => /^:?-{3,}:?$/.test(cell.trim()));
}

function parseTableRow(line) {
	const trimmed = line.trim().replace(/^\||\|$/g, "");
	const cells = [];
	let cell = "";
	let escaped = false;
	let inCodeSpan = false;
	let inHtmlCode = false;

	for (let index = 0; index < trimmed.length; index += 1) {
		const char = trimmed[index];
		const rest = trimmed.slice(index);

		if (escaped) {
			cell += char;
			escaped = false;
			continue;
		}

		if (char === "\\") {
			cell += char;
			escaped = true;
			continue;
		}

		if (!inCodeSpan && rest.toLowerCase().startsWith("<code>")) {
			inHtmlCode = true;
			cell += rest.slice(0, 6);
			index += 5;
			continue;
		}

		if (inHtmlCode && rest.toLowerCase().startsWith("</code>")) {
			inHtmlCode = false;
			cell += rest.slice(0, 7);
			index += 6;
			continue;
		}

		if (!inHtmlCode && char === "`") {
			inCodeSpan = !inCodeSpan;
			cell += char;
			continue;
		}

		if (char === "|" && !inCodeSpan && !inHtmlCode) {
			cells.push(cell.trim());
			cell = "";
			continue;
		}

		cell += char;
	}

	cells.push(cell.trim());
	return cells;
}

function renderTable(rows) {
	if (rows.length < 2 || !isTableSeparator(rows[1])) {
		return rows.map((line) => `<p>${renderInlineMarkdown(line.trim())}</p>`).join("\n");
	}

	const headings = parseTableRow(rows[0]);
	const bodyRows = rows.slice(2).map(parseTableRow);
	return [
		"<table>",
		"<thead>",
		`<tr>${headings.map((cell) => `<th>${renderInlineMarkdown(cell)}</th>`).join("")}</tr>`,
		"</thead>",
		"<tbody>",
		...bodyRows.map((row) => `<tr>${row.map((cell) => `<td>${renderInlineMarkdown(cell)}</td>`).join("")}</tr>`),
		"</tbody>",
		"</table>",
	].join("\n");
}

function renderFencedCode(codeBlock) {
	const commandSwitch = renderAgentCommandFence(codeBlock.lines, codeBlock.language || "");
	if (commandSwitch) return commandSwitch;
	const className = codeBlock.language ? ` class="language-${attributeEscape(codeBlock.language)}"` : "";
	return `<pre><code${className}>${htmlEscape(codeBlock.lines.join("\n"))}</code></pre>`;
}

function renderAgentCommandFence(lines, language) {
	if (language && !/^(bash|sh|shell|zsh)$/.test(language)) return "";
	const commands = { claude: [], codex: [] };
	for (const line of lines) {
		const command = line.trim();
		if (!command) continue;
		if (command.startsWith("claude ")) {
			commands.claude.push(command);
		} else if (command.startsWith("codex ")) {
			commands.codex.push(command);
		} else {
			return "";
		}
	}
	if (commands.claude.length + commands.codex.length < 2) return "";
	return AgentCommandSwitch.render({
		id: `commands-${crypto.createHash("sha1").update(lines.join("\n")).digest("hex").slice(0, 10)}`,
		label: "Agent terminal commands",
		commands,
	});
}

function mergeAgentCommandSections(markdown) {
	return markdown.replace(
		/(^|\n)(?:Claude Code|Claude):[ \t]*(?:\n[ \t]*)+```(bash|sh|shell|zsh)\n([\s\S]*?)\n```[ \t]*(?:\n[ \t]*)+Codex:[ \t]*(?:\n[ \t]*)+```(?:bash|sh|shell|zsh)\n([\s\S]*?)\n```/g,
		(_match, prefix, language, claudeCommands, codexCommands) =>
			`${prefix}\`\`\`${language}\n${claudeCommands.trim()}\n${codexCommands.trim()}\n\`\`\``,
	);
}

function renderMarkdown(markdown) {
	const lines = mergeAgentCommandSections(markdown).replace(/\r\n/g, "\n").split("\n");
	const html = [];
	let paragraph = [];
	let list = null;
	let tableRows = null;
	let codeBlock = null;

	const flushParagraph = () => {
		if (paragraph.length === 0) return;
		html.push(`<p>${renderInlineMarkdown(paragraph.join(" "))}</p>`);
		paragraph = [];
	};
	const flushList = () => {
		if (!list) return;
		html.push(`<${list.type}>`);
		for (const item of list.items) html.push(`<li>${renderInlineMarkdown(item)}</li>`);
		html.push(`</${list.type}>`);
		list = null;
	};
	const flushTable = () => {
		if (!tableRows) return;
		html.push(renderTable(tableRows));
		tableRows = null;
	};
	const flushFlow = () => {
		flushParagraph();
		flushList();
		flushTable();
	};

	for (const line of lines) {
		const fence = line.match(/^```([A-Za-z0-9_-]*)\s*$/);
		if (fence) {
			if (codeBlock) {
				html.push(renderFencedCode(codeBlock));
				codeBlock = null;
			} else {
				flushFlow();
				codeBlock = { language: fence[1], lines: [] };
			}
			continue;
		}

		if (codeBlock) {
			codeBlock.lines.push(line);
			continue;
		}

		if (line.trim() === "") {
			flushFlow();
			continue;
		}

		if (/^\|.*\|$/.test(line.trim())) {
			flushParagraph();
			flushList();
			if (!tableRows) tableRows = [];
			tableRows.push(line);
			continue;
		}

		const heading = line.match(/^(#{1,6})\s+(.+?)\s*#*$/);
		if (heading) {
			flushFlow();
			const level = heading[1].length;
			const text = renderInlineMarkdown(heading[2]);
			const id = level === 1 ? "" : ` id="${attributeEscape(slugifyHeading(heading[2]))}"`;
			html.push(`<h${level}${id}>${text}</h${level}>`);
			continue;
		}

		const unorderedItem = line.match(/^\s*[-*]\s+(.+)/);
		const orderedItem = line.match(/^\s*\d+\.\s+(.+)/);
		if (unorderedItem || orderedItem) {
			flushParagraph();
			flushTable();
			const type = orderedItem ? "ol" : "ul";
			if (!list || list.type !== type) {
				flushList();
				list = { type, items: [] };
			}
			list.items.push((unorderedItem || orderedItem)[1].trim());
			continue;
		}

		if (list && /^\s{2,}\S/.test(line)) {
			list.items[list.items.length - 1] = `${list.items[list.items.length - 1]} ${line.trim()}`;
			continue;
		}

		flushList();
		flushTable();
		paragraph.push(line.trim());
	}

	if (codeBlock) {
		const className = codeBlock.language ? ` class="language-${attributeEscape(codeBlock.language)}"` : "";
		html.push(`<pre><code${className}>${htmlEscape(codeBlock.lines.join("\n"))}</code></pre>`);
	}
	flushFlow();

	return html.join("\n");
}

function markdownTitle(markdown, fallback) {
	const match = markdown.match(/^#\s+(.+?)\s*#*\s*$/m);
	return match ? cleanInline(match[1]) : fallback;
}

function markdownWithoutFirstTitle(markdown) {
	return markdown.replace(/^#\s+.+?\s*#*\s*(?:\r?\n)+/, "");
}

function listDirs(dir) {
	if (!fs.existsSync(dir)) return [];
	return fs
		.readdirSync(dir, { withFileTypes: true })
		.filter((entry) => entry.isDirectory())
		.map((entry) => entry.name)
		.sort();
}

function countFiles(dir) {
	if (!fs.existsSync(dir)) return 0;
	let count = 0;
	for (const entry of fs.readdirSync(dir, { withFileTypes: true })) {
		const fullPath = path.join(dir, entry.name);
		if (entry.isDirectory()) {
			count += countFiles(fullPath);
		} else {
			count += 1;
		}
	}
	return count;
}

function countSkillDirs(pluginDir) {
	return listDirs(path.join(pluginDir, "skills")).filter((skill) => {
		const skillDir = path.join(pluginDir, "skills", skill);
		return ["SKILL.md", "SKILL.claude.md", "SKILL.codex.md"].some((file) =>
			fs.existsSync(path.join(skillDir, file)),
		);
	}).length;
}

function commandCount(pluginDir) {
	const binDir = path.join(pluginDir, "bin");
	if (!fs.existsSync(binDir)) return 0;
	return fs
		.readdirSync(binDir, { withFileTypes: true })
		.filter((entry) => entry.isFile() && !entry.name.endsWith(".md"))
		.length;
}

function parseLatestChange(changelogPath) {
	if (!fs.existsSync(changelogPath)) return null;
	const lines = fs.readFileSync(changelogPath, "utf8").split(/\r?\n/);
	const start = lines.findIndex((line) => /^## \[/.test(line));
	if (start === -1) return null;

	const versionMatch = lines[start].match(/^## \[([^\]]+)\]/);
	const section = [];
	for (let index = start + 1; index < lines.length; index += 1) {
		if (/^## \[/.test(lines[index])) break;
		section.push(lines[index]);
	}

	let type = "Changed";
	let bulletStart = -1;
	for (let index = 0; index < section.length; index += 1) {
		const heading = section[index].match(/^###\s+(.+)/);
		if (heading) type = cleanInline(heading[1]);
		if (/^-\s+/.test(section[index])) {
			bulletStart = index;
			break;
		}
	}

	if (bulletStart === -1) {
		return {
			version: versionMatch ? versionMatch[1] : "latest",
			type,
			summary: "See the package changelog for the latest user-visible note.",
		};
	}

	const bullet = [section[bulletStart].replace(/^-\s+/, "")];
	for (let index = bulletStart + 1; index < section.length; index += 1) {
		const line = section[index];
		if (/^-\s+/.test(line) || /^###\s+/.test(line)) break;
		if (line.trim() === "") continue;
		bullet.push(line.trim());
	}

	return {
		version: versionMatch ? versionMatch[1] : "latest",
		type,
		summary: briefChange(bullet.join(" ")),
	};
}

function compareSemverDesc(a, b) {
	const parse = (value) =>
		String(value)
			.replace(/^v/, "")
			.split(".")
			.map((part) => Number.parseInt(part, 10) || 0);
	const left = parse(a);
	const right = parse(b);
	for (let index = 0; index < Math.max(left.length, right.length); index += 1) {
		const delta = (right[index] || 0) - (left[index] || 0);
		if (delta !== 0) return delta;
	}
	return 0;
}

function build(repoRoot) {
	const claudeMarketplace = readJson(path.join(repoRoot, ".claude-plugin", "marketplace.json"));
	const codexMarketplace = maybeReadJson(path.join(repoRoot, ".agents", "plugins", "marketplace.json"), {
		plugins: [],
	});
	const codexNames = new Set((codexMarketplace.plugins || []).map((plugin) => plugin.name));

	const plugins = (claudeMarketplace.plugins || []).map((entry) => {
		const sourcePath = entry.source.replace(/^\.\//, "");
		const pluginDir = path.join(repoRoot, sourcePath);
		const manifest = readJson(path.join(pluginDir, ".claude-plugin", "plugin.json"));
		const latestChange = parseLatestChange(path.join(pluginDir, "CHANGELOG.md"));
		const support = ["Claude Code"];
		if (codexNames.has(entry.name)) support.push("Codex");
		const detailPath = `agent-fieldkit/${entry.name}/`;

		return {
			name: entry.name,
			version: manifest.version,
			category: (copy[entry.name] || {}).category || "feedback",
			summary: (copy[entry.name] || {}).summary || firstSentence(manifest.description || entry.description || ""),
			support,
			codex: codexNames.has(entry.name),
			detailPath,
			sourcePath,
			sourceUrl: `${REPO_URL}/tree/main/${sourcePath}`,
			skillCount: countSkillDirs(pluginDir),
			commandCount: commandCount(pluginDir),
			hookFileCount: countFiles(path.join(pluginDir, "hooks")),
			latestChange,
		};
	});

	const changelog = plugins
		.filter((plugin) => plugin.latestChange)
		.map((plugin) => ({
			plugin: plugin.name,
			packageVersion: plugin.version,
			detailPath: plugin.detailPath,
			...plugin.latestChange,
			sourceUrl: `${REPO_URL}/blob/main/${plugin.sourcePath}/CHANGELOG.md`,
		}))
		.sort((a, b) => compareSemverDesc(a.packageVersion, b.packageVersion) || a.plugin.localeCompare(b.plugin));

	return {
		generatedBy: "bin/build-pages",
		source: "packages/*/.claude-plugin/plugin.json, packages/*/README.md, packages/*/CHANGELOG.md, .agents/plugins/marketplace.json",
		repository: REPO_URL,
		marketplace: {
			name: claudeMarketplace.name,
			displayName: (claudeMarketplace.owner && claudeMarketplace.owner.name) || "l'Aicluse Agent Fieldkit",
			description:
				(claudeMarketplace.metadata && claudeMarketplace.metadata.description) ||
				"Agent skills marketplace for Claude Code and Codex",
		},
		categories,
		counts: {
			sourcePackages: plugins.length,
			codexPackages: plugins.filter((plugin) => plugin.codex).length,
			claudeOnlyPackages: plugins.filter((plugin) => !plugin.codex).length,
			changelogEntries: changelog.length,
			skillEntries: plugins.reduce((total, plugin) => total + plugin.skillCount, 0),
			hookFiles: plugins.reduce((total, plugin) => total + plugin.hookFileCount, 0),
		},
		install: {
			claude: [
				"claude plugins marketplace add epologee/laicluse-agent-fieldkit",
				...plugins.map((plugin) => `claude plugins install ${plugin.name}@laicluse-agent-fieldkit`),
			],
			codex: [
				"codex plugin marketplace add epologee/laicluse-agent-fieldkit",
				...plugins
					.filter((plugin) => plugin.codex)
					.map((plugin) => `codex plugin add ${plugin.name}@laicluse-agent-fieldkit`),
			],
		},
		plugins,
		changelog,
	};
}

function xmlEscape(value) {
	return String(value)
		.replace(/&/g, "&amp;")
		.replace(/</g, "&lt;")
		.replace(/>/g, "&gt;");
}

function categoryCounts(data) {
	return data.categories
		.map((category) => ({
			label: category.label,
			count: data.plugins.filter((plugin) => plugin.category === category.id).length,
		}))
		.filter((entry) => entry.count > 0);
}

function categoryLabel(data, id) {
	const category = data.categories.find((item) => item.id === id);
	return category ? category.label : id;
}

function sharedAssetVersions(repoRoot) {
	return Object.fromEntries(
		["styles.css", "agent-command-switch.js", "site.js"].map((fileName) => {
			const targetPath = path.join(repoRoot, "docs", fileName);
			const sourcePath = path.join(__dirname, "..", "docs", fileName);
			const assetPath = fs.existsSync(targetPath) ? targetPath : sourcePath;
			const version = crypto.createHash("sha256").update(fs.readFileSync(assetPath)).digest("hex").slice(0, 10);
			return [fileName, version];
		}),
	);
}

function buildPluginDetailPage(data, plugin, markdown, hash, assetVersions) {
	const title = markdownTitle(markdown, plugin.name);
	const readmeHtml = renderMarkdown(markdownWithoutFirstTitle(markdown));
	const pageUrl = `${PAGES_URL}/${plugin.detailPath}`;
	const imageUrl = `${PAGES_URL}/assets/og-image.png?v=${hash}`;
	const installCommands = {
		claude: [`claude plugins install ${plugin.name}@laicluse-agent-fieldkit`],
		codex: plugin.codex ? [`codex plugin add ${plugin.name}@laicluse-agent-fieldkit`] : [],
	};
	const installSwitch = AgentCommandSwitch.render({
		id: `install-${plugin.name}`,
		label: `${plugin.name} install commands`,
		commands: installCommands,
	});

	return `<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8">
		<meta name="viewport" content="width=device-width, initial-scale=1">
		<title>${htmlEscape(title)} · l'Aicluse Agent Fieldkit</title>
		<meta name="description" content="${attributeEscape(plugin.summary)}">
		<link rel="canonical" href="${pageUrl}">

		<meta property="og:type" content="article">
		<meta property="og:site_name" content="l'Aicluse Agent Fieldkit">
		<meta property="og:locale" content="en_US">
		<meta property="og:url" content="${pageUrl}">
		<meta property="og:title" content="${attributeEscape(title)} · l'Aicluse Agent Fieldkit">
		<meta property="og:description" content="${attributeEscape(plugin.summary)}">
		<meta property="og:image" content="${imageUrl}">
		<meta property="og:image:secure_url" content="${imageUrl}">
		<meta property="og:image:type" content="image/png">
		<meta property="og:image:width" content="1200">
		<meta property="og:image:height" content="630">

		<meta name="twitter:card" content="summary_large_image">
		<meta name="twitter:title" content="${attributeEscape(title)} · l'Aicluse Agent Fieldkit">
		<meta name="twitter:description" content="${attributeEscape(plugin.summary)}">
		<meta name="twitter:image" content="${imageUrl}">

		<link rel="stylesheet" href="../../styles.css?v=${assetVersions["styles.css"]}">
		<script src="../../agent-command-switch.js?v=${assetVersions["agent-command-switch.js"]}"></script>
	</head>
	<body>
		<a class="skip-link" href="#content">Skip to content</a>

		<header class="site-header" aria-label="Primary">
			<a class="brand" href="../" aria-label="l'Aicluse Agent Fieldkit home">
				<span class="brand-mark" aria-hidden="true">AF</span>
				<span>l'Aicluse Agent Fieldkit</span>
			</a>
			<nav class="site-nav" aria-label="Sections">
				<a href="../#catalog">Catalog</a>
				<a href="../#install">Install</a>
				<a href="../#changelog">Changelog</a>
				<a href="${attributeEscape(plugin.sourceUrl)}">GitHub</a>
			</nav>
		</header>

		<main id="content" class="detail-page">
			<section class="detail-hero">
				<div class="detail-hero-inner">
					<a class="back-link" href="../#catalog">Catalog</a>
					<p class="eyebrow">${htmlEscape(categoryLabel(data, plugin.category))}</p>
					<h1>${htmlEscape(title)}</h1>
					<p class="lede">${htmlEscape(plugin.summary)}</p>
					<div class="plugin-meta detail-meta" aria-label="Package metadata">
						<span class="support-pill ${plugin.codex ? "both" : "claude"}">${plugin.codex ? "Claude + Codex" : "Claude only"}</span>
						<span>${htmlEscape(plugin.version)}</span>
						<span>${plugin.skillCount} ${plugin.skillCount === 1 ? "skill" : "skills"}</span>
					</div>
				</div>
			</section>

			<section class="detail-content-section">
				<article class="readme-content">
${readmeHtml}
				</article>
				<aside class="detail-sidebar" aria-label="Plugin links">
					<div class="sidebar-block">
						<h2>Install</h2>
						${installSwitch}
					</div>
					<div class="sidebar-block">
						<h2>Source</h2>
						<a href="${attributeEscape(plugin.sourceUrl)}">Package source</a>
					</div>
				</aside>
			</section>
		</main>

		<footer class="site-footer">
			<span>l'Aicluse Agent Fieldkit</span>
			<a href="https://github.com/epologee/laicluse-agent-fieldkit">github.com/epologee/laicluse-agent-fieldkit</a>
		</footer>
	</body>
</html>
`;
}

function renderPluginDetailPages(repoRoot, data, hash, assetVersions) {
	const detailRoot = path.join(repoRoot, "docs", "agent-fieldkit");
	const pluginNames = new Set(data.plugins.map((plugin) => plugin.name));
	fs.mkdirSync(detailRoot, { recursive: true });

	for (const entry of fs.readdirSync(detailRoot, { withFileTypes: true })) {
		if (entry.isDirectory() && !pluginNames.has(entry.name)) {
			fs.rmSync(path.join(detailRoot, entry.name), { recursive: true, force: true });
		}
	}

	for (const plugin of data.plugins) {
		const readmePath = path.join(repoRoot, plugin.sourcePath, "README.md");
		const markdown = fs.readFileSync(readmePath, "utf8");
		const pluginDir = path.join(detailRoot, plugin.name);
		fs.mkdirSync(pluginDir, { recursive: true });
		fs.writeFileSync(path.join(pluginDir, "index.html"), buildPluginDetailPage(data, plugin, markdown, hash, assetVersions));
	}
}

// Build the share card as an SVG string. The plugin count, per-category counts,
// and skill/Codex totals come from the live marketplace data, so the card stays
// in sync every time the page is generated.
function buildOgSvg(data) {
	const pluginCount = data.plugins.length;
	const skillCount = data.counts.skillEntries;

	const cats = categoryCounts(data);
	const pillH = 56;
	const pillFont = 26;
	const charW = 15.6;
	const pillTopY = 452;
	const rowGap = 14;
	const colGap = 16;
	const perRow = Math.ceil(cats.length / 2);
	const pillWidth = (label) => Math.round(58 + label.length * charW + 28);
	const col1Max = Math.max(...cats.filter((_, i) => i % perRow === 0).map((c) => pillWidth(c.label)));
	const colXs = [80, 80 + col1Max + colGap];
	const pills = cats
		.map(({ label, count }, i) => {
			const row = i < perRow ? 0 : 1;
			const col = i - row * perRow;
			const y = pillTopY + row * (pillH + rowGap);
			const baseline = y + pillH / 2 + 9;
			const width = pillWidth(label);
			const x = colXs[col];
			return `	<g>
		<rect x="${x}" y="${y}" width="${width}" height="${pillH}" rx="28" fill="#11150f" stroke="rgba(255,255,255,0.15)"/>
		<text x="${x + 26}" y="${baseline}" font-family="${OG_MONO}" font-size="${pillFont}" font-weight="700" fill="#31d994" stroke="#31d994" stroke-width="0.9">${count}</text>
		<text x="${x + 58}" y="${baseline}" font-family="${OG_MONO}" font-size="${pillFont}" fill="#d7dcd8">${xmlEscape(label)}</text>
	</g>`;
		})
		.join("\n");

	const wmScale = 1040 / WORDMARK.adv;

	return `<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="630" viewBox="0 0 1200 630">
	<defs>
		<radialGradient id="glow" cx="78%" cy="6%" r="55%">
			<stop offset="0%" stop-color="#31d994" stop-opacity="0.20"/>
			<stop offset="62%" stop-color="#31d994" stop-opacity="0"/>
		</radialGradient>
		<pattern id="dots" width="44" height="44" patternUnits="userSpaceOnUse">
			<circle cx="2" cy="2" r="1.4" fill="rgba(255,255,255,0.05)"/>
		</pattern>
	</defs>
	<rect width="1200" height="630" fill="#070807"/>
	<rect width="1200" height="630" fill="url(#dots)"/>
	<rect width="1200" height="630" fill="url(#glow)"/>
	<g transform="translate(80, 164) scale(${wmScale.toFixed(6)}, ${(-wmScale).toFixed(6)})"><path d="${WORDMARK.d}" fill="#f7f7f2"/></g>
	<text x="80" y="262" font-family="${OG_MONO}" font-size="34" font-weight="700" letter-spacing="0.5" fill="#31d994">${pluginCount} PLUGINS · ${skillCount} SKILLS · CLAUDE CODE + CODEX</text>
	<text x="78" y="346" font-family="${OG_SANS}" font-size="54" font-weight="800" letter-spacing="-1.1" fill="#ffffff">Guardrails for coding agents</text>
	<text x="78" y="408" font-family="${OG_SANS}" font-size="54" font-weight="800" letter-spacing="-1.1" xml:space="preserve"><tspan fill="#ffffff">that touch </tspan><tspan fill="#31d994">real repositories.</tspan></text>
${pills}
</svg>
`;
}

function ogHash(buffer) {
	return crypto.createHash("sha256").update(buffer).digest("hex").slice(0, 10);
}

function validatePng(buffer, width, height) {
	const signature = Buffer.from([0x89, 0x50, 0x4e, 0x47, 0x0d, 0x0a, 0x1a, 0x0a]);
	if (buffer.length < 24 || !buffer.subarray(0, 8).equals(signature)) {
		throw new Error("rasterizer did not produce a PNG");
	}
	const actualWidth = buffer.readUInt32BE(16);
	const actualHeight = buffer.readUInt32BE(20);
	if (actualWidth !== width || actualHeight !== height) {
		throw new Error(`og PNG is ${actualWidth}x${actualHeight}, expected ${width}x${height}`);
	}
}

function hasBinary(bin, args) {
	try {
		execFileSync(bin, args, { stdio: "ignore", timeout: 5000 });
		return true;
	} catch {
		return false;
	}
}

// rsvg-convert is the canonical renderer so committed bytes stay reproducible;
// vips is a graceful fallback. Mixing renderers per build would churn the PNG.
function findRenderer() {
	if (hasBinary("rsvg-convert", ["--version"])) {
		return (svgPath, outPath) =>
			execFileSync("rsvg-convert", ["-w", "1200", "-h", "630", "-o", outPath, svgPath], {
				stdio: "ignore",
				timeout: 20000,
			});
	}
	if (hasBinary("vips", ["--version"])) {
		return (svgPath, outPath) =>
			execFileSync("vips", ["thumbnail", svgPath, outPath, "1200", "--height", "630", "--size", "force"], {
				stdio: "ignore",
				timeout: 20000,
			});
	}
	return null;
}

// Write the SVG always; replace the PNG only when its bytes change, so a no-op
// build leaves the binary untouched. Returns the content hash for cache-busting.
function renderOgImage(repoRoot, svg) {
	const assetsDir = path.join(repoRoot, "docs", "assets");
	fs.mkdirSync(assetsDir, { recursive: true });
	const svgPath = path.join(assetsDir, "og-card.svg");
	fs.writeFileSync(svgPath, svg);

	const pngPath = path.join(assetsDir, "og-image.png");
	const keepExisting = () =>
		fs.existsSync(pngPath) ? ogHash(fs.readFileSync(pngPath)) : ogHash(Buffer.from(svg));

	const render = findRenderer();
	if (!render) {
		process.stdout.write("build-pages: no SVG rasterizer (rsvg-convert/vips) found; kept existing og-image.png\n");
		return keepExisting();
	}

	const tmpPath = path.join(assetsDir, ".og-image.tmp.png");
	try {
		render(svgPath, tmpPath);
		const bytes = fs.readFileSync(tmpPath);
		validatePng(bytes, 1200, 630);
		const changed = !fs.existsSync(pngPath) || !fs.readFileSync(pngPath).equals(bytes);
		if (changed) fs.writeFileSync(pngPath, bytes);
		return ogHash(bytes);
	} catch (error) {
		process.stdout.write(`build-pages: og rasterize failed (${error.message}); kept existing og-image.png\n`);
		return keepExisting();
	} finally {
		if (fs.existsSync(tmpPath)) fs.unlinkSync(tmpPath);
	}
}

function replaceHeadUrls(html, pageUrl, imageUrl) {
	return html
		.replace(/<link rel="canonical" href="[^"]*">/, `<link rel="canonical" href="${pageUrl}">`)
		.replace(/<meta property="og:url" content="[^"]*">/, `<meta property="og:url" content="${pageUrl}">`)
		.replace(/<meta property="og:image" content="[^"]*">/, `<meta property="og:image" content="${imageUrl}">`)
		.replace(
			/<meta property="og:image:secure_url" content="[^"]*">/,
			`<meta property="og:image:secure_url" content="${imageUrl}">`,
		)
		.replace(/<meta name="twitter:image" content="[^"]*">/, `<meta name="twitter:image" content="${imageUrl}">`);
}

// Keep the canonical/social URLs tied to PAGES_URL and point the image meta at
// the freshly hashed asset so social platforms refetch the card after it changes.
function updateFieldkitMeta(repoRoot, hash, assetVersions) {
	const indexPath = path.join(repoRoot, "docs", "agent-fieldkit", "index.html");
	const html = fs.readFileSync(indexPath, "utf8");
	const imageUrl = `${PAGES_URL}/assets/og-image.png?v=${hash}`;
	const sharedScripts = `<script src="../agent-command-switch.js?v=${assetVersions["agent-command-switch.js"]}"></script>
		<script src="../site.js?v=${assetVersions["site.js"]}"></script>`;
	const normalized = html.replace(
		/\n?\t\t<script src="\.\.\/agent-command-switch\.js(?:\?v=[0-9a-f]+)?"><\/script>/g,
		"",
	);
	const updated = replaceHeadUrls(normalized, FIELDKIT_URL, imageUrl)
		.replace(
			/<link rel="stylesheet" href="(?:\.\.\/)?styles\.css(?:\?v=[0-9a-f]+)?">/,
			`<link rel="stylesheet" href="../styles.css?v=${assetVersions["styles.css"]}">`,
		)
		.replace(/<script src="site\.js(?:\?v=[0-9a-f]+)?"><\/script>/, sharedScripts)
		.replace(
			/<script src="\.\.\/site\.js(?:\?v=[0-9a-f]+)?"><\/script>/,
			sharedScripts,
		);
	if (updated !== html) fs.writeFileSync(indexPath, updated);
}

function writeSharedAssets(repoRoot) {
	for (const fileName of ["styles.css", "agent-command-switch.js", "site.js"]) {
		const sourcePath = path.join(__dirname, "..", "docs", fileName);
		const targetPath = path.join(repoRoot, "docs", fileName);
		if (path.resolve(sourcePath) !== path.resolve(targetPath)) {
			fs.mkdirSync(path.dirname(targetPath), { recursive: true });
			fs.copyFileSync(sourcePath, targetPath);
		}
	}
}

function buildRootRedirect(hash) {
	const imageUrl = `${PAGES_URL}/assets/og-image.png?v=${hash}`;

	return `<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8">
		<meta name="viewport" content="width=device-width, initial-scale=1">
		<title>${htmlEscape(SITE_TITLE)}</title>
		<meta name="description" content="${attributeEscape(SITE_DESCRIPTION)}">
		<link rel="canonical" href="${FIELDKIT_URL}">
		<meta http-equiv="refresh" content="0; url=/agent-fieldkit/">

		<meta property="og:type" content="website">
		<meta property="og:site_name" content="${htmlEscape(SITE_TITLE)}">
		<meta property="og:locale" content="en_US">
		<meta property="og:url" content="${FIELDKIT_URL}">
		<meta property="og:title" content="${htmlEscape(SITE_TITLE)}">
		<meta property="og:description" content="${attributeEscape(SITE_DESCRIPTION)}">
		<meta property="og:image" content="${imageUrl}">
		<meta property="og:image:secure_url" content="${imageUrl}">
		<meta property="og:image:type" content="image/png">
		<meta property="og:image:width" content="1200">
		<meta property="og:image:height" content="630">
		<meta property="og:image:alt" content="${attributeEscape(SITE_IMAGE_ALT)}">

		<meta name="twitter:card" content="summary_large_image">
		<meta name="twitter:title" content="${htmlEscape(SITE_TITLE)}">
		<meta name="twitter:description" content="${attributeEscape(SITE_TWITTER_DESCRIPTION)}">
		<meta name="twitter:image" content="${imageUrl}">
		<meta name="twitter:image:alt" content="${attributeEscape(SITE_TWITTER_IMAGE_ALT)}">

		<script>
			(() => {
				const target = new URL("/agent-fieldkit/", window.location.origin);
				target.search = window.location.search;
				target.hash = window.location.hash;
				window.location.replace(target.href);
			})();
		</script>
	</head>
	<body>
		<p><a href="/agent-fieldkit/">Continue to l'Aicluse Agent Fieldkit.</a></p>
	</body>
</html>
`;
}

function writeRootRedirect(repoRoot, hash) {
	fs.writeFileSync(path.join(repoRoot, "docs", "index.html"), buildRootRedirect(hash));
}

function main() {
	const repoRoot = path.resolve(process.argv[2] || process.cwd());
	const data = build(repoRoot);
	const outputPath = path.join(repoRoot, "docs", "site-data.json");
	fs.mkdirSync(path.dirname(outputPath), { recursive: true });
	fs.writeFileSync(outputPath, `${JSON.stringify(data, null, "\t")}\n`);
	process.stdout.write(`build-pages: wrote ${path.relative(repoRoot, outputPath)}\n`);

	const hash = renderOgImage(repoRoot, buildOgSvg(data));
	writeSharedAssets(repoRoot);
	const assetVersions = sharedAssetVersions(repoRoot);
	updateFieldkitMeta(repoRoot, hash, assetVersions);
	writeRootRedirect(repoRoot, hash);
	renderPluginDetailPages(repoRoot, data, hash, assetVersions);
	process.stdout.write(`build-pages: og-image hash ${hash}\n`);
}

main();
