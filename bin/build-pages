const categories = [
	{
		id: "workflow",
		label: "Repository discipline",
		description: "The guardrails that keep fast agent work from leaving shared state messy.",
	},
	{
		id: "autonomy",
		label: "Autonomous work",
		description: "Longer missions with explicit phases, wake paths, checks, and stopping points.",
	},
	{
		id: "review",
		label: "Review and language",
		description: "Second reads, duplication audits, naming doctrine, and structured critique.",
	},
	{
		id: "feedback",
		label: "Feedback and utilities",
		description: "The small loops that turn irritation, confusion, and repeated friction into maintainable fixes.",
	},
];

function readJson(file) {
	return JSON.parse(fs.readFileSync(file, "utf8"));
}

function maybeReadJson(file, fallback) {
	if (!fs.existsSync(file)) return fallback;
	return readJson(file);
}

function cleanInline(value) {
	return value
		.replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
		.replace(/`([^`]+)`/g, "$1")
		.replace(/\*\*([^*]+)\*\*/g, "$1")
		.replace(/\*/g, "")
		.replace(/\s+/g, " ")
		.trim();
}

function firstSentence(value) {
	const cleaned = cleanInline(value);
	const match = cleaned.match(/^(.{80,220}?[.!?])\s/);
	return match ? match[1] : cleaned.slice(0, 190);
}

function briefChange(value) {
	const cleaned = cleanInline(value);
	const sentence = cleaned.match(/^(.{1,280}?[.!?])(?:\s|$)/);
	if (sentence) return sentence[1];
	if (cleaned.length <= 260) return cleaned;
	return `${cleaned.slice(0, 257).replace(/\s+\S*$/, "")}...`;
}

function listDirs(dir) {
	if (!fs.existsSync(dir)) return [];
	return fs
		.readdirSync(dir, { withFileTypes: true })
		.filter((entry) => entry.isDirectory())
		.map((entry) => entry.name)
		.sort();
}

function countFiles(dir) {
	if (!fs.existsSync(dir)) return 0;
	let count = 0;
	for (const entry of fs.readdirSync(dir, { withFileTypes: true })) {
		const fullPath = path.join(dir, entry.name);
		if (entry.isDirectory()) {
			count += countFiles(fullPath);
		} else {
			count += 1;
		}
	}
	return count;
}

function countSkillDirs(pluginDir) {
	return listDirs(path.join(pluginDir, "skills")).filter((skill) => {
		const skillDir = path.join(pluginDir, "skills", skill);
		return ["SKILL.md", "SKILL.claude.md", "SKILL.codex.md"].some((file) =>
			fs.existsSync(path.join(skillDir, file)),
		);
	}).length;
}

function commandCount(pluginDir) {
	const binDir = path.join(pluginDir, "bin");
	if (!fs.existsSync(binDir)) return 0;
	return fs
		.readdirSync(binDir, { withFileTypes: true })
		.filter((entry) => entry.isFile() && !entry.name.endsWith(".md"))
		.length;
}

function parseLatestChange(changelogPath) {
	if (!fs.existsSync(changelogPath)) return null;
	const lines = fs.readFileSync(changelogPath, "utf8").split(/\r?\n/);
	const start = lines.findIndex((line) => /^## \[/.test(line));
	if (start === -1) return null;

	const versionMatch = lines[start].match(/^## \[([^\]]+)\]/);
	const section = [];
	for (let index = start + 1; index < lines.length; index += 1) {
		if (/^## \[/.test(lines[index])) break;
		section.push(lines[index]);
	}

	let type = "Changed";
	let bulletStart = -1;
	for (let index = 0; index < section.length; index += 1) {
		const heading = section[index].match(/^###\s+(.+)/);
		if (heading) type = cleanInline(heading[1]);
		if (/^-\s+/.test(section[index])) {
			bulletStart = index;
			break;
		}
	}

	if (bulletStart === -1) {
		return {
			version: versionMatch ? versionMatch[1] : "latest",
			type,
			summary: "See the package changelog for the latest user-visible note.",
		};
	}

	const bullet = [section[bulletStart].replace(/^-\s+/, "")];
	for (let index = bulletStart + 1; index < section.length; index += 1) {
		const line = section[index];
		if (/^-\s+/.test(line) || /^###\s+/.test(line)) break;
		if (line.trim() === "") continue;
		bullet.push(line.trim());
	}

	return {
		version: versionMatch ? versionMatch[1] : "latest",
		type,
		summary: briefChange(bullet.join(" ")),
	};
}

function compareSemverDesc(a, b) {
	const parse = (value) =>
		String(value)
			.replace(/^v/, "")
			.split(".")
			.map((part) => Number.parseInt(part, 10) || 0);
	const left = parse(a);
	const right = parse(b);
	for (let index = 0; index < Math.max(left.length, right.length); index += 1) {
		const delta = (right[index] || 0) - (left[index] || 0);
		if (delta !== 0) return delta;
	}
	return 0;
}

function build(repoRoot) {
	const claudeMarketplace = readJson(path.join(repoRoot, ".claude-plugin", "marketplace.json"));
	const codexMarketplace = maybeReadJson(path.join(repoRoot, ".agents", "plugins", "marketplace.json"), {
		plugins: [],
	});
	const codexNames = new Set((codexMarketplace.plugins || []).map((plugin) => plugin.name));

	const plugins = (claudeMarketplace.plugins || []).map((entry) => {
		const sourcePath = entry.source.replace(/^\.\//, "");
		const pluginDir = path.join(repoRoot, sourcePath);
		const manifest = readJson(path.join(pluginDir, ".claude-plugin", "plugin.json"));
		const latestChange = parseLatestChange(path.join(pluginDir, "CHANGELOG.md"));
		const support = ["Claude Code"];
		if (codexNames.has(entry.name)) support.push("Codex");

		return {
			name: entry.name,
			version: manifest.version,
			category: (copy[entry.name] || {}).category || "feedback",
			summary: (copy[entry.name] || {}).summary || firstSentence(manifest.description || entry.description || ""),
			support,
			codex: codexNames.has(entry.name),
			sourcePath,
			sourceUrl: `${REPO_URL}/tree/main/${sourcePath}`,
			skillCount: countSkillDirs(pluginDir),
			commandCount: commandCount(pluginDir),
			hookFileCount: countFiles(path.join(pluginDir, "hooks")),
			latestChange,
		};
	});

	const changelog = plugins
		.filter((plugin) => plugin.latestChange)
		.map((plugin) => ({
			plugin: plugin.name,
			packageVersion: plugin.version,
			...plugin.latestChange,
			sourceUrl: `${REPO_URL}/blob/main/${plugin.sourcePath}/CHANGELOG.md`,
		}))
		.sort((a, b) => compareSemverDesc(a.packageVersion, b.packageVersion) || a.plugin.localeCompare(b.plugin));

	return {
		generatedBy: "bin/build-pages",
		source: "packages/*/.claude-plugin/plugin.json, packages/*/CHANGELOG.md, .agents/plugins/marketplace.json",
		repository: REPO_URL,
		marketplace: {
			name: claudeMarketplace.name,
			displayName: (claudeMarketplace.owner && claudeMarketplace.owner.name) || "l'Aicluse Agent Fieldkit",
			description:
				(claudeMarketplace.metadata && claudeMarketplace.metadata.description) ||
				"Agent skills marketplace for Claude Code and Codex",
		},
		categories,
		counts: {
			sourcePackages: plugins.length,
			codexPackages: plugins.filter((plugin) => plugin.codex).length,
			claudeOnlyPackages: plugins.filter((plugin) => !plugin.codex).length,
			changelogEntries: changelog.length,
			skillEntries: plugins.reduce((total, plugin) => total + plugin.skillCount, 0),
			hookFiles: plugins.reduce((total, plugin) => total + plugin.hookFileCount, 0),
		},
		install: {
			claude: [
				"claude plugins marketplace add epologee/laicluse-agent-fieldkit",
				...plugins.map((plugin) => `claude plugins install ${plugin.name}@laicluse-agent-fieldkit`),
			],
			codex: [
				"codex plugin marketplace add epologee/laicluse-agent-fieldkit",
				...plugins
					.filter((plugin) => plugin.codex)
					.map((plugin) => `codex plugin add ${plugin.name}@laicluse-agent-fieldkit`),
			],
		},
		plugins,
		changelog,
	};
}

function xmlEscape(value) {
	return String(value)
		.replace(/&/g, "&amp;")
		.replace(/</g, "&lt;")
		.replace(/>/g, "&gt;");
}

function categoryCounts(data) {
	return data.categories
		.map((category) => ({
			label: category.label,
			count: data.plugins.filter((plugin) => plugin.category === category.id).length,
		}))
		.filter((entry) => entry.count > 0);
}

// Build the share card as an SVG string. The plugin count, per-category counts,
// and skill/Codex totals come from the live marketplace data, so the card stays
// in sync every time the page is generated.
function buildOgSvg(data) {
	const pluginCount = data.plugins.length;
	const skillCount = data.counts.skillEntries;

	let x = 80;
	const pillY = 496;
	const pillH = 44;
	const pills = categoryCounts(data)
		.map(({ label, count }) => {
			const width = Math.round(52 + label.length * 9.0 + 26);
			const group = `	<g>
		<rect x="${x}" y="${pillY}" width="${width}" height="${pillH}" rx="22" fill="#11150f" stroke="rgba(255,255,255,0.15)"/>
		<circle cx="${x + 22}" cy="${pillY + pillH / 2}" r="4.5" fill="#31d994"/>
		<text x="${x + 38}" y="${pillY + pillH / 2 + 5}" font-family="${OG_MONO}" font-size="15" fill="#d7dcd8">${xmlEscape(label)}</text>
		<text x="${x + width - 20}" y="${pillY + pillH / 2 + 5}" text-anchor="end" font-family="${OG_MONO}" font-size="15" font-weight="700" fill="#31d994">${count}</text>
	</g>`;
			x += width + 12;
			return group;
		})
		.join("\n");

	return `<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="630" viewBox="0 0 1200 630">
	<defs>
		<radialGradient id="glow" cx="78%" cy="6%" r="55%">
			<stop offset="0%" stop-color="#31d994" stop-opacity="0.20"/>
			<stop offset="62%" stop-color="#31d994" stop-opacity="0"/>
		</radialGradient>
		<pattern id="dots" width="44" height="44" patternUnits="userSpaceOnUse">
			<circle cx="2" cy="2" r="1.4" fill="rgba(255,255,255,0.05)"/>
		</pattern>
	</defs>
	<rect width="1200" height="630" fill="#070807"/>
	<rect width="1200" height="630" fill="url(#dots)"/>
	<rect width="1200" height="630" fill="url(#glow)"/>
	<text x="80" y="158" font-family="${OG_SANS}" font-size="32" font-weight="700" fill="#f7f7f2">l'Aicluse Agent Fieldkit</text>
	<text x="80" y="270" font-family="${OG_MONO}" font-size="21" letter-spacing="1.5" fill="#31d994">${pluginCount} PLUGINS · ${skillCount} SKILLS · CLAUDE CODE + CODEX</text>
	<text x="78" y="352" font-family="${OG_SANS}" font-size="58" font-weight="800" letter-spacing="-1.2" fill="#ffffff">Guardrails for coding agents</text>
	<text x="78" y="420" font-family="${OG_SANS}" font-size="58" font-weight="800" letter-spacing="-1.2" xml:space="preserve"><tspan fill="#ffffff">that touch </tspan><tspan fill="#31d994">real repositories.</tspan></text>
${pills}
</svg>
`;
}

function ogHash(buffer) {
	return crypto.createHash("sha256").update(buffer).digest("hex").slice(0, 10);
}

function validatePng(buffer, width, height) {
	const signature = Buffer.from([0x89, 0x50, 0x4e, 0x47, 0x0d, 0x0a, 0x1a, 0x0a]);
	if (buffer.length < 24 || !buffer.subarray(0, 8).equals(signature)) {
		throw new Error("rasterizer did not produce a PNG");
	}
	const actualWidth = buffer.readUInt32BE(16);
	const actualHeight = buffer.readUInt32BE(20);
	if (actualWidth !== width || actualHeight !== height) {
		throw new Error(`og PNG is ${actualWidth}x${actualHeight}, expected ${width}x${height}`);
	}
}

function hasBinary(bin, args) {
	try {
		execFileSync(bin, args, { stdio: "ignore", timeout: 5000 });
		return true;
	} catch {
		return false;
	}
}

// rsvg-convert is the canonical renderer so committed bytes stay reproducible;
// vips is a graceful fallback. Mixing renderers per build would churn the PNG.
function findRenderer() {
	if (hasBinary("rsvg-convert", ["--version"])) {
		return (svgPath, outPath) =>
			execFileSync("rsvg-convert", ["-w", "1200", "-h", "630", "-o", outPath, svgPath], {
				stdio: "ignore",
				timeout: 20000,
			});
	}
	if (hasBinary("vips", ["--version"])) {
		return (svgPath, outPath) =>
			execFileSync("vips", ["thumbnail", svgPath, outPath, "1200", "--height", "630", "--size", "force"], {
				stdio: "ignore",
				timeout: 20000,
			});
	}
	return null;
}

// Write the SVG always; replace the PNG only when its bytes change, so a no-op
// build leaves the binary untouched. Returns the content hash for cache-busting.
function renderOgImage(repoRoot, svg) {
	const assetsDir = path.join(repoRoot, "docs", "assets");
	fs.mkdirSync(assetsDir, { recursive: true });
	const svgPath = path.join(assetsDir, "og-card.svg");
	fs.writeFileSync(svgPath, svg);

	const pngPath = path.join(assetsDir, "og-image.png");
	const keepExisting = () =>
		fs.existsSync(pngPath) ? ogHash(fs.readFileSync(pngPath)) : ogHash(Buffer.from(svg));

	const render = findRenderer();
	if (!render) {
		process.stdout.write("build-pages: no SVG rasterizer (rsvg-convert/vips) found; kept existing og-image.png\n");
		return keepExisting();
	}

	const tmpPath = path.join(assetsDir, ".og-image.tmp.png");
	try {
		render(svgPath, tmpPath);
		const bytes = fs.readFileSync(tmpPath);
		validatePng(bytes, 1200, 630);
		const changed = !fs.existsSync(pngPath) || !fs.readFileSync(pngPath).equals(bytes);
		if (changed) fs.writeFileSync(pngPath, bytes);
		return ogHash(bytes);
	} catch (error) {
		process.stdout.write(`build-pages: og rasterize failed (${error.message}); kept existing og-image.png\n`);
		return keepExisting();
	} finally {
		if (fs.existsSync(tmpPath)) fs.unlinkSync(tmpPath);
	}
}

// Point the og:image/twitter:image meta at the freshly hashed asset so social
// platforms refetch the card after it changes.
function updateOgMeta(repoRoot, hash) {
	const indexPath = path.join(repoRoot, "docs", "index.html");
	const html = fs.readFileSync(indexPath, "utf8");
	const updated = html.replace(/(assets\/og-image\.png)(\?v=[a-z0-9]+)?/g, `$1?v=${hash}`);
	if (updated !== html) fs.writeFileSync(indexPath, updated);
}

function main() {
	const repoRoot = path.resolve(process.argv[2] || process.cwd());
	const data = build(repoRoot);
	const outputPath = path.join(repoRoot, "docs", "site-data.json");
	fs.mkdirSync(path.dirname(outputPath), { recursive: true });
	fs.writeFileSync(outputPath, `${JSON.stringify(data, null, "\t")}\n`);
	process.stdout.write(`build-pages: wrote ${path.relative(repoRoot, outputPath)}\n`);

	const hash = renderOgImage(repoRoot, buildOgSvg(data));
	updateOgMeta(repoRoot, hash);
	process.stdout.write(`build-pages: og-image hash ${hash}\n`);
}

main();
