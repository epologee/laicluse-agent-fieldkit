#!/usr/bin/env node
"use strict";

const fs = require("fs");
const path = require("path");
const crypto = require("crypto");
const { execFileSync } = require("child_process");

const REPO_URL = "https://github.com/epologee/laicluse-agent-fieldkit";
const PAGES_URL = "https://epologee.github.io/laicluse-agent-fieldkit";
const OG_SANS = "Inter, -apple-system, 'Segoe UI', Roboto, sans-serif";
const OG_MONO = "'SFMono-Regular', Menlo, Consolas, monospace";

