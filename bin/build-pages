function writeRootPage(repoRoot, hash, assetVersions) {
	fs.writeFileSync(path.join(repoRoot, "docs", "index.html"), buildRootPage(hash, assetVersions));
}

function main() {
	const repoRoot = path.resolve(process.argv[2] || process.cwd());
	const data = build(repoRoot);
	const outputPath = path.join(repoRoot, "docs", "site-data.json");
	fs.mkdirSync(path.dirname(outputPath), { recursive: true });
	fs.writeFileSync(outputPath, `${JSON.stringify(data, null, "\t")}\n`);
	process.stdout.write(`build-pages: wrote ${path.relative(repoRoot, outputPath)}\n`);

	const vocalistApp = data.apps.find((item) => item.name === "Vocalist");
	const supermaxApp = data.openSource.find((item) => item.name === "Supermax");
	const hash = renderOgImage(repoRoot, buildOgSvg(data));
	const rootHash = renderOgImage(repoRoot, buildRootOgSvg(data), {
		svgFileName: "root-og-card.svg",
		pngFileName: "root-og-image.png",
	});
	const vocalistHash = vocalistApp
		? renderOgImage(repoRoot, buildVocalistOgSvg(vocalistApp), {
				svgFileName: "vocalist-og-card.svg",
				pngFileName: "vocalist-og-image.png",
			})
		: hash;
	const supermaxHash = supermaxApp
		? renderOgImage(repoRoot, buildSupermaxOgSvg(supermaxApp), {
				svgFileName: "supermax-og-card.svg",
				pngFileName: "supermax-og-image.png",
			})
		: hash;
	writeSharedAssets(repoRoot);
	const assetVersions = sharedAssetVersions(repoRoot);
	updateFieldkitMeta(repoRoot, hash, assetVersions);
	writeRootPage(repoRoot, rootHash, assetVersions);
	renderPluginDetailPages(repoRoot, data, hash, assetVersions);
	renderVocalistPage(repoRoot, data, vocalistHash, assetVersions);
	renderSupermaxPage(repoRoot, data, supermaxHash, assetVersions);
	process.stdout.write(`build-pages: og-image hash ${hash}\n`);
	process.stdout.write(`build-pages: root-og-image hash ${rootHash}\n`);
	process.stdout.write(`build-pages: vocalist-og-image hash ${vocalistHash}\n`);
	process.stdout.write(`build-pages: supermax-og-image hash ${supermaxHash}\n`);
}

main();
