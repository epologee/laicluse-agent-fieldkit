			<stop offset="100%" stop-color="#080a08"/>
		</linearGradient>
		<filter id="softShadow" x="-20%" y="-20%" width="140%" height="140%">
			<feDropShadow dx="0" dy="18" stdDeviation="18" flood-color="#000000" flood-opacity="0.34"/>
		</filter>
	</defs>
	<rect width="1200" height="630" fill="#070807"/>
	<rect width="1200" height="630" fill="url(#grid)"/>
	<rect x="56" y="56" width="1088" height="518" rx="34" fill="url(#panel)" stroke="rgba(255,255,255,0.13)" stroke-width="2"/>
	${renderOgWordmark({ x: 88, y: 80, width: 270, fill: "#31d994" })}
	<text x="380" y="140" font-family="${OG_SANS}" font-size="44" font-weight="800" fill="#31d994">Open Source</text>
	<text x="88" y="264" font-family="${OG_SANS}" font-size="108" font-weight="850" fill="#ffffff">${xmlEscape(app.name)}</text>
	<text x="92" y="348" font-family="${OG_SANS}" font-size="40" font-weight="750" fill="#f7f7f2">Multi-pane layout for responsive apps.</text>
	<g>
		<rect x="92" y="470" width="330" height="62" rx="31" fill="rgba(112,167,255,0.12)" stroke="rgba(112,167,255,0.62)" stroke-width="2"/>
		<text x="130" y="510" font-family="${OG_MONO}" font-size="25" font-weight="800" fill="#70a7ff">@laicluse/supermax</text>
	</g>
	<text x="92" y="432" font-family="${OG_MONO}" font-size="25" font-weight="800" fill="#31d994" data-max-width="360" data-width-factor="0.62">framework-free ESM</text>
	<g filter="url(#softShadow)">
		<rect x="620" y="136" width="438" height="360" rx="30" fill="#0d1110" stroke="rgba(255,255,255,0.16)" stroke-width="2"/>
		<text x="660" y="194" font-family="${OG_MONO}" font-size="24" font-weight="800" fill="#a8b0aa">24 cols</text>
		<rect x="660" y="238" width="76" height="168" rx="16" fill="#0f766e"/>
		<rect x="750" y="238" width="98" height="168" rx="16" fill="#7c3aed"/>
		<rect x="862" y="238" width="142" height="168" rx="16" fill="#0b6bcb"/>
		<rect x="660" y="424" width="344" height="30" rx="15" fill="rgba(49,217,148,0.18)" stroke="rgba(49,217,148,0.45)" stroke-width="2"/>
		<text x="685" y="333" font-family="${OG_MONO}" font-size="18" font-weight="800" fill="#ffffff" text-anchor="middle">Menu</text>
		<text x="799" y="333" font-family="${OG_MONO}" font-size="18" font-weight="800" fill="#ffffff" text-anchor="middle">List</text>
		<text x="933" y="333" font-family="${OG_MONO}" font-size="20" font-weight="800" fill="#ffffff" text-anchor="middle">Article</text>
		<text x="832" y="446" font-family="${OG_MONO}" font-size="20" font-weight="800" fill="#31d994" text-anchor="middle">zoom anchor keeps the article visible</text>
	</g>
</svg>
`;
}

function buildRootOgSvg(data) {
	const appCount = data.apps.length;
	const openSourceCount = data.openSource.length;
	const pluginCount = data.plugins.length;
	const appLabel = formatCount(appCount, "app");
	const openSourceLabel = formatCount(openSourceCount, "open source", "open source");
	const pluginLabel = formatCount(pluginCount, "plugin");

	return `<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="630" viewBox="0 0 1200 630">
	<defs>
		<pattern id="grid" width="48" height="48" patternUnits="userSpaceOnUse">
			<path d="M 48 0 L 0 0 0 48" fill="none" stroke="rgba(255,255,255,0.055)" stroke-width="1"/>
		</pattern>
		<linearGradient id="fade" x1="0%" y1="0%" x2="100%" y2="100%">
			<stop offset="0%" stop-color="#0d120e"/>
			<stop offset="50%" stop-color="#070807"/>
			<stop offset="100%" stop-color="#0d100f"/>
		</linearGradient>
	</defs>
	<rect width="1200" height="630" fill="#070807"/>
	<rect width="1200" height="630" fill="url(#fade)"/>
	<rect width="1200" height="630" fill="url(#grid)"/>
	<rect x="54" y="52" width="1092" height="526" rx="34" fill="rgba(255,255,255,0.018)" stroke="rgba(255,255,255,0.14)" stroke-width="2"/>
	${renderOgWordmark({ x: 320, y: 82, width: 560, fill: "#f7f7f2" })}
	<text x="600" y="374" text-anchor="middle" font-family="${OG_SANS}" font-size="40" font-weight="760" fill="#f7f7f2">Open source, apps, and plugins for humans and coding agents</text>
	<g>
		<rect x="242" y="444" width="204" height="66" rx="33" fill="rgba(49,217,148,0.10)" stroke="rgba(49,217,148,0.58)" stroke-width="2"/>
		<text x="344" y="486" text-anchor="middle" font-family="${OG_MONO}" font-size="25" font-weight="850" fill="#31d994">${appLabel}</text>
		<rect x="474" y="444" width="252" height="66" rx="33" fill="rgba(247,247,242,0.055)" stroke="rgba(255,255,255,0.20)" stroke-width="2"/>
		<text x="600" y="486" text-anchor="middle" font-family="${OG_MONO}" font-size="25" font-weight="850" fill="#f7f7f2">${openSourceLabel}</text>
		<rect x="754" y="444" width="204" height="66" rx="33" fill="rgba(246,180,75,0.11)" stroke="rgba(246,180,75,0.58)" stroke-width="2"/>
		<text x="856" y="486" text-anchor="middle" font-family="${OG_MONO}" font-size="25" font-weight="850" fill="#f6b44b">${pluginLabel}</text>
	</g>
</svg>
`;
}

function ogHash(buffer) {
	return crypto.createHash("sha256").update(buffer).digest("hex").slice(0, 10);
}

function validatePng(buffer, width, height) {
	const signature = Buffer.from([0x89, 0x50, 0x4e, 0x47, 0x0d, 0x0a, 0x1a, 0x0a]);
	if (buffer.length < 24 || !buffer.subarray(0, 8).equals(signature)) {
		throw new Error("rasterizer did not produce a PNG");
	}
	const actualWidth = buffer.readUInt32BE(16);
	const actualHeight = buffer.readUInt32BE(20);
	if (actualWidth !== width || actualHeight !== height) {
		throw new Error(`og PNG is ${actualWidth}x${actualHeight}, expected ${width}x${height}`);
	}
}

function hasBinary(bin, args) {
	try {
		execFileSync(bin, args, { stdio: "ignore", timeout: 5000 });
		return true;
	} catch {
		return false;
	}
}

// rsvg-convert is the canonical renderer so committed bytes stay reproducible;
// vips is a graceful fallback. Mixing renderers per build would churn the PNG.
function findRenderer() {
	if (hasBinary("rsvg-convert", ["--version"])) {
		return (svgPath, outPath) =>
			execFileSync("rsvg-convert", ["-w", "1200", "-h", "630", "-o", outPath, svgPath], {
				stdio: "ignore",
				timeout: 20000,
			});
	}
	if (hasBinary("vips", ["--version"])) {
		return (svgPath, outPath) =>
			execFileSync("vips", ["thumbnail", svgPath, outPath, "1200", "--height", "630", "--size", "force"], {
				stdio: "ignore",
				timeout: 20000,
			});
	}
	return null;
}

// Write the SVG always; replace the PNG only when its bytes change, so a no-op
// build leaves the binary untouched. Returns the content hash for cache-busting.
function renderOgImage(repoRoot, svg, options = {}) {
	const svgFileName = options.svgFileName || "og-card.svg";
	const pngFileName = options.pngFileName || "og-image.png";
	const assetsDir = path.join(repoRoot, "docs", "assets");
	fs.mkdirSync(assetsDir, { recursive: true });
	const svgPath = path.join(assetsDir, svgFileName);
	fs.writeFileSync(svgPath, svg);

	const pngPath = path.join(assetsDir, pngFileName);
	const keepExisting = () =>
		fs.existsSync(pngPath) ? ogHash(fs.readFileSync(pngPath)) : ogHash(Buffer.from(svg));

	const render = findRenderer();
	if (!render) {
		process.stdout.write("build-pages: no SVG rasterizer (rsvg-convert/vips) found; kept existing og-image.png\n");
		return keepExisting();
	}

	const tmpPath = path.join(assetsDir, `.${pngFileName}.tmp`);
	try {
		render(svgPath, tmpPath);
		const bytes = fs.readFileSync(tmpPath);
		validatePng(bytes, 1200, 630);
		const changed = !fs.existsSync(pngPath) || !fs.readFileSync(pngPath).equals(bytes);
		if (changed) fs.writeFileSync(pngPath, bytes);
		return ogHash(bytes);
	} catch (error) {
		process.stdout.write(`build-pages: og rasterize failed (${error.message}); kept existing og-image.png\n`);
		return keepExisting();
	} finally {
		if (fs.existsSync(tmpPath)) fs.unlinkSync(tmpPath);
	}
}

function replaceHeadUrls(html, pageUrl, imageUrl) {
	return html
		.replace(/<link rel="canonical" href="[^"]*">/, `<link rel="canonical" href="${pageUrl}">`)
		.replace(/<meta property="og:url" content="[^"]*">/, `<meta property="og:url" content="${pageUrl}">`)
		.replace(/<meta property="og:image" content="[^"]*">/, `<meta property="og:image" content="${imageUrl}">`)
		.replace(
			/<meta property="og:image:secure_url" content="[^"]*">/,
			`<meta property="og:image:secure_url" content="${imageUrl}">`,
		)
		.replace(/<meta name="twitter:image" content="[^"]*">/, `<meta name="twitter:image" content="${imageUrl}">`);
}

// Keep the canonical/social URLs tied to PAGES_URL and point the image meta at
// the freshly hashed asset so social platforms refetch the card after it changes.
function updateFieldkitMeta(repoRoot, hash, assetVersions) {
	const indexPath = path.join(repoRoot, "docs", "agent-fieldkit", "index.html");
	const html = fs.readFileSync(indexPath, "utf8");
	const imageUrl = `${PAGES_URL}/assets/og-image.png?v=${hash}`;
	const sharedScripts = `<script src="../code-panel-copy.js?v=${assetVersions["code-panel-copy.js"]}"></script>
		<script src="../agent-command-switch.js?v=${assetVersions["agent-command-switch.js"]}"></script>
		<script src="../site.js?v=${assetVersions["site.js"]}"></script>`;
	const normalized = html.replace(
		/\n?\t\t<script src="\.\.\/agent-command-switch\.js(?:\?v=[0-9a-f]+)?"><\/script>/g,
		"",
	).replace(
		/\n?\t\t<script src="\.\.\/code-panel-copy\.js(?:\?v=[0-9a-f]+)?"><\/script>/g,
		"",
	);
	const updated = replaceHeadUrls(normalized, FIELDKIT_URL, imageUrl)
		.replace(
			/<link rel="stylesheet" href="(?:\.\.\/)?styles\.css(?:\?v=[0-9a-f]+)?">/,
			`<link rel="stylesheet" href="../styles.css?v=${assetVersions["styles.css"]}">`,
		)
		.replace(/<script src="site\.js(?:\?v=[0-9a-f]+)?"><\/script>/, sharedScripts)
		.replace(
			/<script src="\.\.\/site\.js(?:\?v=[0-9a-f]+)?"><\/script>/,
			sharedScripts,
		)
		.replace(/<span class="brand-title">l'Aicluse Agent Fieldkit<\/span>/, renderWordmarkBrand("Agent Fieldkit"));
	if (updated !== html) fs.writeFileSync(indexPath, updated);
}

function writeSharedAssets(repoRoot) {
	for (const fileName of ["styles.css", "code-panel-copy.js", "agent-command-switch.js", "site.js"]) {
		const sourcePath = path.join(__dirname, "..", "docs", fileName);
		const targetPath = path.join(repoRoot, "docs", fileName);
		if (path.resolve(sourcePath) !== path.resolve(targetPath)) {
			fs.mkdirSync(path.dirname(targetPath), { recursive: true });
			fs.copyFileSync(sourcePath, targetPath);
		}
	}
	for (const fileName of ["laicluse-wordmark.svg"]) {
		const sourcePath = path.join(__dirname, "..", "docs", "assets", fileName);
		const targetPath = path.join(repoRoot, "docs", "assets", fileName);
		if (path.resolve(sourcePath) !== path.resolve(targetPath)) {
			fs.mkdirSync(path.dirname(targetPath), { recursive: true });
			fs.copyFileSync(sourcePath, targetPath);
		}
	}
}

